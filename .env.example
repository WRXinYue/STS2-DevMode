# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit real keys.

# -------------------------------------------------------------------
# STS2 install paths (scripts/init.py, make sync)
# -------------------------------------------------------------------

# Active Steam install for make sync / local.props Sts2Dir
STS2_DIR=

# Compile-time API line for STS2_DIR (local.props Sts2Profile). Values: stable | beta
STS2_PROFILE=

# Optional fallback when eng/sts2-refs/ is missing (normally not needed):
# STS2_DIR_STABLE=
# STS2_DIR_BETA=

# Dual-profile builds use Git LFS refs under eng/sts2-refs/ (see eng/sts2-refs/README.md).
# Refresh: switch Steam branch → make capture-sts2-ref PROFILE=stable|beta

# -------------------------------------------------------------------
# Nexus Mods upload (scripts/publish_nexus.py / make upload-nexus)
# -------------------------------------------------------------------

# Personal API key — https://www.nexusmods.com/settings/api-keys
NEXUS_API_KEY=

# File group ID for stable/public KitLib — mod page → Main file → API Info
NEXUS_FILE_GROUP_ID=

# Optional file group ID for STS2 Steam beta builds (separate Optional file line)
NEXUS_FILE_GROUP_ID_BETA=

# Optional file group ID for KitLib.Mcp stdio proxy (separate Optional file line)
NEXUS_FILE_GROUP_ID_MCP=

# -------------------------------------------------------------------
# NuGet upload (scripts/publish_nuget.py / make upload-nuget)
# -------------------------------------------------------------------

# API key for nuget.org or GitHub Packages
NUGET_API_KEY=

# Feed URL (default: https://api.nuget.org/v3/index.json)
# GitHub Packages example: https://nuget.pkg.github.com/WRXinYue/index.json
NUGET_SOURCE=
